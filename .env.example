# Where contact-form leads are delivered (defaults to jmandelmvp@gmail.com)
CONTACT_TO=jmandelmvp@gmail.com

# SMTP credentials used to send the email.
# For Gmail: enable 2-Step Verification, then create an "App Password"
# (https://myaccount.google.com/apppasswords) and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jmandelmvp@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional friendly From header (must be allowed by your SMTP provider)
SMTP_FROM="TechCare Website <jmandelmvp@gmail.com>"
