# Where contact-form leads are delivered (defaults to jmandelmvp@gmail.com)
CONTACT_TO=jmandelmvp@gmail.com

# Resend (https://resend.com) is used to send the email.
# 1. Sign up at https://resend.com and create an API key.
# 2. Paste it below.
RESEND_API_KEY=re_your_api_key_here

# Sender address shown on the email. Until you verify your own domain in
# Resend, you must use their shared sandbox sender below. Once you verify a
# domain (Resend dashboard -> Domains), you can send from your own address,
# e.g. "Gateway Tech Website <leads@yourdomain.com>".
RESEND_FROM="Gateway Tech Website <onboarding@resend.dev>"
